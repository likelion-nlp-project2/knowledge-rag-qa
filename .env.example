# docker-compose 용 환경변수. 복사해서 .env 로 쓰고 값 채우기: cp .env.example .env
# (.env 는 .gitignore 에 이미 제외되어 있음)

# Cloudflare Tunnel 토큰.
# Cloudflare Zero Trust 대시보드 > Networks > Tunnels 에서 터널을 만들고
# "Docker" 커넥터로 뜨는 토큰(eyJ... 로 시작)을 여기에 붙여넣는다.
# 그리고 대시보드의 Public Hostname 라우팅에서 서비스를 http://api:8080 으로 지정한다.
TUNNEL_TOKEN=

# 검색 임베딩 모델 (rag/config.py EMBED_MODELS 의 key). 채택: bge-m3
EMBED_MODEL=bge-m3

# RTX 3060(12GB) 기준. OOM 나면 128 등으로 낮춘다.
INGEST_BATCH=256

# GPU fp16 사용(1) / fp32(0)
FP16=1
